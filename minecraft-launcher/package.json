{
  "name": "minecraft-launcher-skeleton",
  "version": "0.1.0",
  "description": "Prosty szkic launcher'a Minecraft (uruchamia wybrany plik wykonywalny).",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.rivlas.minecraftlauncher",
    "productName": "Rivlas Minecraft Launcher",
    "files": [
      "**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": ["nsis", "portable"],
      "artifactName": "${productName}-setup-${version}.${ext}"
    }
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  }
}
